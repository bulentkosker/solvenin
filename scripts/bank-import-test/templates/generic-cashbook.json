{
  "name": "Generic Cashbook — Günlük Kasa/Banka Defteri (XLSX)",
  "file_format": "xlsx",
  "country_code": "KZ",
  "language_code": "tr",
  "bank_name": null,
  "bank_identifier": null,

  "locale": {
    "decimal_separator": ".",
    "thousand_separator": "",
    "date_format": "DD.MM.YYYY"
  },

  "sheet_pattern": ".*",
  "sheet_date_format": "DD.MM.YYYY",

  "sections": [
    {
      "name": "cash",
      "sheet_pattern": ".*",
      "start_row": 7,
      "end_detection": "first_empty_in_col_B",
      "columns": {
        "number": "B",
        "description": "C",
        "debit": "D",
        "credit": "E"
      }
    },
    {
      "name": "bank",
      "sheet_pattern": ".*",
      "start_row": 7,
      "end_detection": "first_empty_in_col_B",
      "columns": {
        "number": "I",
        "description": "J",
        "debit": "K",
        "credit": "L"
      }
    }
  ],

  "metadata": {
    "cash_opening_balance": {
      "method": "cell",
      "sheet": 0,
      "cell": "D5"
    },
    "bank_opening_balance": {
      "method": "cell",
      "sheet": 0,
      "cell": "K5"
    }
  }
}
