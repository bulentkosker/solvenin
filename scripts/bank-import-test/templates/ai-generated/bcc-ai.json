{
  "name": "BCC Bank KZ — Есепшоттар бойынша айналым (PDF, landscape)",
  "file_format": "pdf",
  "country_code": "KZ",
  "language_code": "ru",
  "bank_name": "Bank CenterCredit",
  "bank_identifier": "KCJBKZKX",
  "locale": {
    "decimal_separator": ",",
    "thousand_separator": " ",
    "date_format": "DD.MM.YYYY"
  },
  "row_detection": {
    "method": "y_coordinate_grouping",
    "pattern": "^\\d{2}\\.\\d{2}\\.\\d{4}$",
    "y_tolerance": 4,
    "skip_header_y": 300,
    "date_x_min": 62,
    "date_x_max": 107,
    "stop_pattern": "Жиынтығы|Итого|Исходящее"
  },
  "fields": {
    "transaction_date": {
      "method": "x_coordinate_range",
      "x_min": 62,
      "x_max": 107
    },
    "document_number": {
      "method": "x_coordinate_range",
      "x_min": 28,
      "x_max": 60
    },
    "counterparty_bik": {
      "method": "x_coordinate_range",
      "x_min": 112,
      "x_max": 159
    },
    "counterparty_iban": {
      "method": "x_coordinate_range",
      "x_min": 157,
      "x_max": 237
    },
    "sender_bin": {
      "method": "x_coordinate_range",
      "x_min": 233,
      "x_max": 290
    },
    "receiver_bin": {
      "method": "x_coordinate_range",
      "x_min": 364,
      "x_max": 421
    },
    "debit": {
      "method": "x_coordinate_range",
      "x_min": 427,
      "x_max": 545,
      "use_all_rows": true
    },
    "credit": {
      "method": "x_coordinate_range",
      "x_min": 490,
      "x_max": 565,
      "use_all_rows": true
    },
    "knp_code": {
      "method": "x_coordinate_range",
      "x_min": 566,
      "x_max": 588
    },
    "bank_correspondent": {
      "method": "x_coordinate_range",
      "x_min": 593,
      "x_max": 681
    },
    "counterparty_name": {
      "method": "x_coordinate_range",
      "x_min": 292,
      "x_max": 367,
      "use_all_rows": true
    },
    "payment_details": {
      "method": "x_coordinate_range",
      "x_min": 692,
      "x_max": 850,
      "use_all_rows": true
    },
    "counterparty_bin": {
      "method": "regex_in_field",
      "pattern": "\\b(\\d{12})\\b",
      "group": 1
    },
    "transaction_time": {
      "method": "regex_in_field",
      "pattern": "(\\d{2}:\\d{2})",
      "group": 1
    }
  },
  "metadata": {
    "account_iban": {
      "method": "regex",
      "pattern": "ЖСК\\s*/\\s*ИИК[:\\s]+(KZ\\d{18,20})"
    },
    "opening_balance": {
      "method": "regex",
      "pattern": "Входящее\\s+сальдо\\s*[:/]\\s*([\\d\\s,.]+)"
    },
    "closing_balance": {
      "method": "regex",
      "pattern": "Исходящее\\s+сальдо\\s*[:/]\\s*([\\d\\s,.]+)"
    },
    "period_start": {
      "method": "regex",
      "pattern": "c\\s+(\\d{2}\\.\\d{2}\\.\\d{4})",
      "date_format": "DD.MM.YYYY"
    },
    "period_end": {
      "method": "regex",
      "pattern": "по\\s+(\\d{2}\\.\\d{2}\\.\\d{4})",
      "date_format": "DD.MM.YYYY"
    },
    "client_bin": {
      "method": "regex",
      "pattern": "ИИН\\s*/\\s*БИН[:\\s]+(\\d{12})"
    },
    "bank_bik": {
      "method": "regex",
      "pattern": "БСК\\s*/\\s*БИК[:\\s]+(\\w+)"
    }
  }
}