{
  "name": "Turkish Cashbook — Günlük Kasa/Banka Defteri (XLSX)",
  "file_format": "xlsx",
  "country_code": "TR",
  "language_code": "tr",
  "bank_name": null,
  "bank_identifier": null,
  "locale": {
    "decimal_separator": ".",
    "thousand_separator": "",
    "date_format": "DD.MM.YYYY"
  },
  "sheet_date_format": "DD.MM.YYYY",
  "sections": [
    {
      "name": "cash",
      "sheet_pattern": ".*",
      "start_row": 6,
      "end_detection": "first_empty_in_col_B",
      "columns": {
        "number": "B",
        "description": "C",
        "debit": "D",
        "credit": "E"
      }
    },
    {
      "name": "bank",
      "sheet_pattern": ".*",
      "start_row": 6,
      "end_detection": "first_empty_in_col_I",
      "columns": {
        "number": "I",
        "description": "J",
        "debit": "K",
        "credit": "L"
      }
    }
  ],
  "fields": {
    "transaction_date": {
      "method": "sheet_name_date"
    },
    "document_number": {
      "method": "column"
    },
    "payment_details": {
      "method": "column"
    },
    "debit": {
      "method": "column"
    },
    "credit": {
      "method": "column"
    }
  },
  "metadata": {
    "cash_opening_balance": {
      "method": "regex",
      "pattern": "D E V R E D E N.*?(\\d+(?:\\.\\d+)?)"
    },
    "bank_opening_balance": {
      "method": "regex",
      "pattern": "D E V R E D E N.*?(\\d+(?:\\.\\d+)?)"
    },
    "cash_closing_balance": {
      "method": "regex",
      "pattern": "GUN KASA DEVIR BAKIYE.*?(\\d+(?:\\.\\d+)?)"
    },
    "bank_closing_balance": {
      "method": "regex",
      "pattern": "GUN KASA DEVIR BAKIYE.*?(\\d+(?:\\.\\d+)?)"
    }
  }
}