{
  "name": "Turkish Cashbook — Günlük Kasa/Banka Defteri (XLSX)",
  "file_format": "xlsx",
  "country_code": "TR",
  "language_code": "tr",
  "bank_name": null,
  "bank_identifier": null,
  "locale": {
    "decimal_separator": ".",
    "thousand_separator": "",
    "date_format": "DD.MM.YYYY"
  },
  "sheet_pattern": "\\d{2}\\.\\d{2}\\.\\d{4}",
  "sheet_date_format": "DD.MM.YYYY",
  "sections": [
    {
      "name": "cash",
      "sheet_pattern": ".*",
      "start_row": 7,
      "end_pattern": "T O P L A M L A R",
      "columns": {
        "number": "B",
        "description": "C",
        "debit": "D",
        "credit": "E"
      }
    },
    {
      "name": "bank",
      "sheet_pattern": ".*",
      "start_row": 7,
      "end_pattern": "T O P L A M L A R",
      "columns": {
        "number": "I",
        "description": "J",
        "debit": "K",
        "credit": "L"
      }
    }
  ],
  "fields": {
    "transaction_date": {
      "method": "sheet_name_date"
    },
    "entry_number": {
      "method": "column_value"
    },
    "description": {
      "method": "column_value"
    },
    "debit": {
      "method": "column_value"
    },
    "credit": {
      "method": "column_value"
    }
  },
  "metadata": {
    "cash_opening_balance": {
      "method": "cell_regex",
      "pattern": "D E V R E D E N",
      "value_column": "D"
    },
    "bank_opening_balance": {
      "method": "cell_regex",
      "pattern": "D E V R E D E N",
      "value_column": "K"
    },
    "cash_closing_balance": {
      "method": "cell_regex",
      "pattern": "DEVIR BAKIYE",
      "value_column": "D"
    },
    "bank_closing_balance": {
      "method": "cell_regex",
      "pattern": "DEVIR BAKIYE",
      "value_column": "K"
    },
    "cash_total_debit": {
      "method": "cell_regex",
      "pattern": "T O P L A M L A R",
      "value_column": "D"
    },
    "cash_total_credit": {
      "method": "cell_regex",
      "pattern": "T O P L A M L A R",
      "value_column": "E"
    },
    "bank_total_debit": {
      "method": "cell_regex",
      "pattern": "T O P L A M L A R",
      "value_column": "K"
    },
    "bank_total_credit": {
      "method": "cell_regex",
      "pattern": "T O P L A M L A R",
      "value_column": "L"
    },
    "period_date": {
      "method": "sheet_name_date",
      "date_format": "DD.MM.YYYY"
    }
  }
}