{
  "name": "Generic Cashbook — Günlük Kasa/Banka Defteri (XLSX)",
  "file_format": "xlsx",
  "country_code": "TR",
  "language_code": "tr",
  "bank_name": null,
  "bank_identifier": null,
  "locale": {
    "decimal_separator": ".",
    "thousand_separator": "",
    "date_format": "DD.MM.YYYY"
  },
  "sheet_pattern": "\\d{2}\\.\\d{2}\\.\\d{4}",
  "sheet_date_format": "DD.MM.YYYY",
  "sections": [
    {
      "name": "cash",
      "sheet_pattern": ".*",
      "start_row": 7,
      "end_detection": "stop_pattern",
      "stop_pattern": "T O P L A M L A R",
      "columns": {
        "number": "B",
        "description": "C",
        "debit": "D",
        "credit": "E"
      },
      "filters": {
        "skip_empty_description": true,
        "skip_zero_amounts": false
      }
    },
    {
      "name": "bank",
      "sheet_pattern": ".*",
      "start_row": 7,
      "end_detection": "stop_pattern",
      "stop_pattern": "T O P L A M L A R",
      "columns": {
        "number": "I",
        "description": "J",
        "debit": "K",
        "credit": "L"
      },
      "filters": {
        "skip_empty_description": true,
        "skip_zero_amounts": false
      }
    }
  ],
  "fields": {
    "transaction_date": {
      "method": "sheet_name",
      "date_format": "DD.MM.YYYY"
    },
    "entry_number": {
      "method": "section_column",
      "section": "cash",
      "column": "number"
    },
    "description": {
      "method": "section_column",
      "section": "cash",
      "column": "description"
    },
    "cash_debit": {
      "method": "section_column",
      "section": "cash",
      "column": "debit"
    },
    "cash_credit": {
      "method": "section_column",
      "section": "cash",
      "column": "credit"
    },
    "bank_debit": {
      "method": "section_column",
      "section": "bank",
      "column": "debit"
    },
    "bank_credit": {
      "method": "section_column",
      "section": "bank",
      "column": "credit"
    },
    "bank_description": {
      "method": "section_column",
      "section": "bank",
      "column": "description"
    }
  },
  "metadata": {
    "cash_opening_balance": {
      "method": "cell_pattern",
      "pattern": "D E V R E D E N",
      "value_offset": [
        0,
        1
      ],
      "section": "cash"
    },
    "bank_opening_balance": {
      "method": "cell_pattern",
      "pattern": "D E V R E D E N",
      "value_offset": [
        0,
        1
      ],
      "section": "bank"
    },
    "cash_closing_balance": {
      "method": "cell_pattern",
      "pattern": "GUN KASA DEVIR BAKIYE",
      "value_offset": [
        0,
        1
      ],
      "section": "cash"
    },
    "bank_closing_balance": {
      "method": "cell_pattern",
      "pattern": "GUN KASA DEVIR BAKIYE",
      "value_offset": [
        0,
        1
      ],
      "section": "bank"
    },
    "period_date": {
      "method": "sheet_name",
      "date_format": "DD.MM.YYYY"
    }
  }
}